# ============================================
# Content Creation Studio - Environment Configuration
# Codelab Starter
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Google AI API Key
# Get from: https://aistudio.google.com
# ============================================
GOOGLE_API_KEY=your_google_ai_api_key_here

# ============================================
# Agent Model Configuration
# ============================================
QUALITY_SCORE_THRESHOLD=70
MAX_IMPROVEMENT_ITERATIONS=2

# ============================================
# (Optional) Google Cloud - only needed for deployment steps
# ============================================
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_CLOUD_STORAGE_BUCKET=gs://your-project-id-content-studio
# AGENT_ENGINE_RESOURCE_NAME=projects/YOUR_PROJECT_ID/locations/YOUR_LOCATION/reasoningEngines/YOUR_ENGINE_ID
